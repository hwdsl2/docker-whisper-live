# Note: All the variables to this image are optional.
# See README for more information.
# To use, copy this file to 'whisper-live.env' and uncomment/set your values.
# For the CUDA image (whisper-live-server:cuda), GPU acceleration is used
# automatically when an NVIDIA GPU is available.

# Whisper model to use for transcription (default: base)
# Options: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en,
#          large-v1, large-v2, large-v3, large-v3-turbo, turbo
# - Models are downloaded from HuggingFace on first client connection and cached
#   in the /var/lib/whisper-live Docker volume.
# - large-v3-turbo is recommended if you need better accuracy than 'base'
#   without the full resource cost of large-v3.
# - Use an '.en' variant (e.g. base.en) for a slight speed boost on English-only audio.
# WHISPERLIVE_MODEL=base

# Default language for transcription (default: auto)
# - Set to a BCP-47 language code (e.g. en, fr, de, zh, ja, es) to skip
#   language autodetection and improve speed/accuracy for known-language audio.
# - Leave as 'auto' or unset to autodetect the language from each audio chunk.
# WHISPERLIVE_LANGUAGE=auto

# WebSocket port for real-time streaming clients (default: 9090)
# WHISPERLIVE_PORT=9090

# HTTP port for the OpenAI-compatible REST API (default: 8000)
# WHISPERLIVE_REST_PORT=8000

# Maximum number of simultaneous WebSocket client connections (default: 4)
# WHISPERLIVE_MAX_CLIENTS=4

# Maximum WebSocket connection duration in seconds (default: 600)
# - Clients that exceed this duration are disconnected automatically.
# WHISPERLIVE_MAX_CONNECTION_TIME=600

# Enable Voice Activity Detection (default: true)
# - Controls the default 'use_vad' value shown in the startup log.
# - For the faster_whisper backend, VAD is set per WebSocket client in the
#   connection handshake. Clients that do not send a 'use_vad' field will
#   use whatever the server defaults to internally.
# - Set to false to indicate clients should stream audio without VAD filtering.
# WHISPERLIVE_USE_VAD=true

# Number of CPU threads used for inference (default: 2)
# - Used for CPU-based inference. On the CUDA image, GPU handles inference;
#   this setting still controls thread count for non-GPU operations.
# - Increase on hosts with many cores to improve throughput for concurrent sessions.
# - Set to the number of physical CPU cores for best single-session latency.
# WHISPERLIVE_THREADS=2

# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# WHISPERLIVE_LOG_LEVEL=INFO

# Optional API key to require authentication for REST and WebSocket clients.
# - Fresh installs with a mounted /var/lib/whisper-live volume auto-generate a key.
# - Existing installs with no key remain open for backward compatibility.
# - REST requests must include: -H "Authorization: Bearer <key>"
# - WebSocket clients can use: ws://host:9090?token=<key>
# - Set explicitly empty (WHISPERLIVE_API_KEY=) to disable authentication.
# - Use 'docker exec <container> whisper_live_manage --showkey' to display the key.
# - Use 'docker exec <container> whisper_live_manage --getkey' for scripts.
# - Keep this secret if you expose the server to the internet.
# WHISPERLIVE_API_KEY=

# Local-only mode: disable all HuggingFace model downloads (default: unset)
# - When set to any non-empty value (e.g. true), faster-whisper will only use
#   models already present in the /var/lib/whisper-live cache volume and will not
#   attempt to contact HuggingFace. Useful for air-gapped or offline deployments.
# - Leave unset (default) to allow automatic model downloads on first client connection.
# WHISPERLIVE_LOCAL_ONLY=
